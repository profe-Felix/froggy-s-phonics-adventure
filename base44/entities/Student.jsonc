{
  "name": "Student",
  "type": "object",
  "properties": {
    "student_number": {
      "type": "integer",
      "description": "Student number (1-30)"
    },
    "name": {
      "type": "string",
      "description": "Optional student name"
    },
    "class_name": {
      "type": "string",
      "description": "Class identifier, e.g. F, V, C"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Assessment grouping tags e.g. 'Math SG 1', 'Decoding SG 2'",
      "default": []
    },
    "active_pet": {
      "type": "string",
      "description": "ID of currently active pet"
    },
    "unlocked_pets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of unlocked pet IDs"
    },
    "pending_pet_unlocks": {
      "type": "integer",
      "description": "Number of mystery box reveals waiting",
      "default": 0
    },
    "unlocked_fruits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of fruit emojis collected (one per 75 spelling pts)",
      "default": []
    },
    "spelling_total_points": {
      "type": "integer",
      "description": "Lifetime spelling points across spelling + sight words spelling modes",
      "default": 0
    },
    "sentences_total_points": {
      "type": "integer",
      "description": "Lifetime sentence points",
      "default": 0
    },
    "sentence_prize_spins_claimed": {
      "type": "integer",
      "description": "Number of sentence prize wheel spins already claimed",
      "default": 0
    },
    "redeemed_prizes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Prize IDs claimed forever (one-time prizes like ring)",
      "default": []
    },
    "prize_history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Every prize wheel result claimed by the student",
      "default": []
    },
    "active_prizes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Prize IDs currently active (e.g. cushion, friend, lollipop). Teacher manages these.",
      "default": []
    },
    "cushion_since": {
      "type": "number",
      "description": "Unix timestamp when cushion prize was granted, for FIFO eviction"
    },
    "mode_progress": {
      "type": "object",
      "properties": {
        "letter_sounds": {
          "type": "object",
          "properties": {
            "mastered_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "learning_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "item_attempts": {
              "type": "object"
            },
            "total_correct": {
              "type": "integer"
            },
            "total_attempts": {
              "type": "integer"
            },
            "unlocked": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "sight_words_easy": {
          "type": "object",
          "properties": {
            "mastered_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "learning_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "item_attempts": {
              "type": "object"
            },
            "total_correct": {
              "type": "integer"
            },
            "total_attempts": {
              "type": "integer"
            },
            "unlocked": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "sight_words_spelling": {
          "type": "object",
          "properties": {
            "mastered_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "learning_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "item_attempts": {
              "type": "object"
            },
            "total_correct": {
              "type": "integer"
            },
            "total_attempts": {
              "type": "integer"
            },
            "unlocked": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "spelling": {
          "type": "object",
          "properties": {
            "mastered_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "learning_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "item_attempts": {
              "type": "object"
            },
            "total_correct": {
              "type": "integer"
            },
            "total_attempts": {
              "type": "integer"
            },
            "unlocked": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "case_matching": {
          "type": "object",
          "properties": {
            "mastered_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "learning_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "item_attempts": {
              "type": "object"
            },
            "total_correct": {
              "type": "integer"
            },
            "total_attempts": {
              "type": "integer"
            },
            "unlocked": {
              "type": "boolean",
              "default": false
            }
          }
        }
      }
    },
    "current_mode": {
      "type": "string",
      "enum": [
        "letter_sounds",
        "sight_words_easy",
        "sight_words_spelling",
        "spelling",
        "case_matching"
      ],
      "default": "letter_sounds"
    }
  },
  "required": [
    "student_number"
  ]
}